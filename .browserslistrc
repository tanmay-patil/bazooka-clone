# Modern browsers with WebSocket and WebP support
# This enables removal of PNG fallbacks and ensures real-time capabilities

# Production - WebP support requirements
Chrome >= 89
Firefox >= 85
Safari >= 14
Edge >= 89
and_chr >= 89
and_ff >= 85
ios_saf >= 14

# Explicitly exclude browsers without WebP/WebSocket support
not ie <= 11
not op_mini all
not android <= 4.4
not safari < 14
not chrome < 89
not firefox < 85
not edge < 89
